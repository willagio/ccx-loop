# .ccx-config — dogfood metadata (informational only).
#
# This file is committed in this repository ONLY because ccx-loop is the
# ccx tooling's own dogfood. A customer repo MUST NOT commit a .ccx-config:
# T-6's `ccx verify` rejects this file in any checkout where
# `git config --get --type=bool ccx.dogfood` does not return `true`.
#
# This file is declarative. The supervisor, plan, loop, forever, and
# inspection helpers (/ccx:where, /ccx:board, /ccx:tasks, /ccx:link,
# /ccx:unlink) read their gates from `git config ccx.*` — per-clone,
# not committed. Auto-detection ("am I the ccx repo?") is explicitly
# rejected; a fresh clone of this repo opts into dogfood mode with:
#
#     git config ccx.dogfood true
#
# See docs/supervisor-design.md §18 ("Customer-mode invisibility") for
# the full behavior matrix that the flag controls.

[ccx]
# Default for fresh clones of THIS repository. Customer repos that
# carry this value through cloning still need to run the git-config
# command above — the value here is documentation, not a config source.
dogfood = true
